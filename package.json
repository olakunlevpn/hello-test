{
  "name": "custom-mail-client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:token-worker": "set -a && source .env && source .env.local && set +a && npx tsx src/workers/token-refresh.worker.ts",
    "dev:webhook-worker": "set -a && source .env && source .env.local && set +a && npx tsx src/workers/webhook.worker.ts",
    "dev:all": "npm run dev:workers && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "build:workers": "tsc -p tsconfig.workers.json",
    "build:all": "npm run build && npm run build:workers"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fluentui/react-components": "^9.73.7",
    "@fluentui/react-icons": "^2.0.323",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@remixicon/react": "^4.9.0",
    "@tiptap/extension-link": "^3.22.0",
    "@tiptap/extension-underline": "^3.22.0",
    "@tiptap/pm": "^3.22.0",
    "@tiptap/react": "^3.22.0",
    "@tiptap/starter-kit": "^3.22.0",
    "@types/dompurify": "^3.0.5",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.72.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "dotenv": "^17.4.0",
    "ioredis": "^5.10.1",
    "javascript-obfuscator": "^5.4.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jest": "^30.3.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
