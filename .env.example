# Microsoft Azure AD (configure after registration)
MICROSOFT_CLIENT_ID=your-application-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret-value
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback
MICROSOFT_SCOPES=offline_access openid email profile User.Read User.ReadWrite Mail.Read Mail.ReadBasic Mail.ReadWrite Mail.Send Mail.Read.Shared Mail.ReadBasic.Shared Mail.ReadWrite.Shared Mail.Send.Shared Contacts.Read Contacts.ReadWrite Contacts.Read.Shared Contacts.ReadWrite.Shared People.Read SMTP.Send Directory.Read.All Files.Read Files.ReadWrite Notes.Read Notes.ReadWrite Team.ReadBasic.All Channel.ReadBasic.All Calendars.Read

# Database
DATABASE_URL=postgresql://forg365:forg365_dev@localhost:5432/forg365_db

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-32-char-string

# Token Encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=generate-a-random-64-hex-char-string

# Webhook
WEBHOOK_CLIENT_STATE=generate-a-random-secret-string

# BitGo
BITGO_API_KEY=your-bitgo-api-key
BITGO_WALLET_ID=your-bitgo-wallet-id
BITGO_IS_TEST_MODE=true
BITGO_SERVER_IPADDRESS=127.0.0.1
BITGO_REQUIRED_CONFIRMATIONS=2
BITGO_WEBHOOK_SECRET=your-bitgo-webhook-secret

# Billing
PLAN_PRICE_MONTHLY_USD=29
PLAN_PRICE_YEARLY_USD=290

# Platform Domain (used for custom domain CNAME instructions)
NEXT_PUBLIC_PLATFORM_DOMAIN=multitenant.sbs

# Domain Verification (token returned by /api/domain-verify endpoint)
DOMAIN_VERIFY_TOKEN=generate-a-random-string

# Cloudflare (for cache purging on deploy)
CF_API_TOKEN=your-cloudflare-api-token
CF_ZONE_ID=your-cloudflare-zone-id

# Deploy Notifications (Telegram bot for deploy alerts)
TG_DEPLOY_BOT_TOKEN=your-telegram-bot-token
TG_DEPLOY_CHAT_ID=your-telegram-chat-id
